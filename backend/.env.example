# --- API Keys ---
# Voyage AI credentials (required for embeddings and reranking)
VOYAGE_API_KEY2=your_voyage_api_key_here

# Groq API credentials (optional, used for fast Llama inference)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API credentials (optional, used for fallback inference)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API credentials (optional, fallback for inference)
OPENAI_API_KEY=your_openai_api_key_here

# Fireflies API key (optional, for fetching meeting details)
FIREFLIES_API_KEY=your_fireflies_api_key_here

# --- Vector Store Configuration ---
# Which vector store to use:
#   chroma   -> embedded ChromaDB (default, no server needed)
#   pgvector -> PostgreSQL + pgvector
VECTOR_BACKEND=chroma
CHROMA_DIR=backend/chroma_db

# PostgreSQL Connection URI (only used when VECTOR_BACKEND=pgvector)
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/ripplebot

# --- Server Settings ---
PORT=8000
HOST=0.0.0.0
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
